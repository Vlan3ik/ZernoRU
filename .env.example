# Docker будет слушать на всех сетевых интерфейсах, чтобы сайт был доступен в локальной сети.
# Для доступа с других устройств используйте IP вашего компьютера в LAN: http://<LAN_IP>:18081
LAN_BIND=0.0.0.0

# Необязательно. Укажите LAN IP компьютера, если HMR/WebSocket Vite нестабильно работает через nginx.
# Пример: LAN_HOST=192.168.1.50
LAN_HOST=

# Порты, доступные с локальной сети.
APP_PORT=18081
FRONTEND_PORT=15173
BACKEND_PORT=18080
POSTGRES_PORT=15432
PGADMIN_PORT=15050
MINIO_PORT=19000
MINIO_CONSOLE_PORT=19001

# Если npm плохо качается из вашей сети.
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com/
